# Faucet wallet private key is stored in macOS Keychain.
# Run: ./setup-faucet.sh to store it.
# Service: "morpheus-faucet-wallet" in Keychain Access.app

# BASE RPC endpoint
RPC_URL=https://mainnet.base.org

# MOR token contract on BASE
MOR_TOKEN=0x7431aDa8a591C955a994a21710752EF9b882b8e3

# Amount to send per invite
MOR_AMOUNT=3
ETH_AMOUNT=0.005

# Budget caps (stop sending when reached)
MAX_TOTAL_MOR=300
MAX_TOTAL_ETH=0.5

# Server port
PORT=3456
