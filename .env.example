# === Jeff Suite Configuration ===
# Run ./scripts/setup.sh to generate this file automatically.
# Only ETH_NODE_ADDRESS needs your input -- everything else is pre-filled.

# --- YOUR RPC ENDPOINT ---
# BASE mainnet RPC URL. Get a free one from:
#   Alchemy: https://dashboard.alchemy.com (create app, select "Base" network)
#   Infura:  https://app.infura.io (create project, select "Base" network)
# The public endpoint works but is rate-limited.
ETH_NODE_ADDRESS=https://mainnet.base.org

# --- WALLET (managed by setup.sh -- do not edit) ---
# The actual key is stored in macOS Keychain ("morpheus-consumer-wallet").
# start.sh reads it from Keychain at runtime and passes it to Docker.
# This sentinel value tells start.sh to use Keychain lookup.
WALLET_PRIVATE_KEY=KEYCHAIN

# --- BLOCKCHAIN (do not change) ---
ETH_NODE_CHAIN_ID=8453
DIAMOND_CONTRACT_ADDRESS=0x6aBE1d282f72B474E54527D93b979A4f64d3030a
MOR_TOKEN_ADDRESS=0x7431aDa8a591C955a994a21710752EF9b882b8e3
BLOCKSCOUT_API_URL=https://base.blockscout.com/api/v2

# --- PROXY-ROUTER (do not change unless you know what you're doing) ---
PROXY_ADDRESS=0.0.0.0:3333
WEB_ADDRESS=0.0.0.0:8082
WEB_PUBLIC_URL=http://localhost:8082

# --- AUTH ---
# Admin credentials for the proxy-router API.
# Scripts use these to authenticate curl requests.
COOKIE_CONTENT=admin:morpheus

# --- PATHS (container-internal, do not change) ---
AUTH_CONFIG_FILE_PATH=/app/data/proxy.conf
COOKIE_FILE_PATH=/app/data/.cookie
PROXY_STORAGE_PATH=/app/data/data
MODELS_CONFIG_PATH=/app/data/models-config.json
RATING_CONFIG_PATH=/app/data/rating-config.json
